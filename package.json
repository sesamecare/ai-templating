{
  "name": "@sesamecare-oss/ai-templating",
  "version": "0.0.0",
  "description": "Manage prompts and skills using Langfuse and local filesystem with Handlebars templating",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": [
    "build",
    "README.md"
  ],
  "author": "Developers <developers@sesamecare.com>",
  "license": "UNLICENSED",
  "packageManager": "yarn@3.8.7",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "yarn dlx rimraf ./build ./tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "postinstall": "cpconfig",
    "prepublishOnly": "yarn build",
    "test": "vitest run"
  },
  "keywords": [
    "typescript",
    "handlebars",
    "langfuse",
    "ai",
    "sesame"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sesamecare/ai-templating.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "publishCmd": "yarn dlx pinst --disable"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "config": {
    "cpconfig": "@openapi-typescript-infra/cpconfig"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.4.0",
    "@langfuse/client": "^5.9.1",
    "@langfuse/core": "^5.9.1",
    "@openapi-typescript-infra/service": "^6.14.1",
    "@sesamecare-oss/async-pool": "^1.0.5",
    "@sesamecare-oss/rule-evaluator": "^1.0.0",
    "ai": "^6.0.220",
    "date-fns": "^4.4.0",
    "handlebars": "^4.7.9",
    "handlebars-helpers": "^0.10.0"
  },
  "devDependencies": {
    "@openapi-typescript-infra/cpconfig": "^1.1.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.9",
    "@types/handlebars-helpers": "^0.5.6",
    "@types/node": "^25.9.4",
    "cpconfig": "^1.5.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
